{
  "manifest_version": 3,
  "name": "dao · rt-flow 浏览器版 · 切号 + 内网穿透 + 多实例",
  "short_name": "rt-flow mobile",
  "version": "1.7.0",
  "description": "rt-flow 本体的浏览器/手机端移植：账号池 → email+password 换 auth1 → 点击切号即注入 app.devin.ai 自动登录。万法识别批量加号、对话实时追踪(含综合健康度)、账号本源概览、对话下载到手机(MD+JSON+HTML 三位一体·单文件直开)、知识库/剧本下载、水过无痕清理、Git 批量归一/连断(PAT)。二合一: service worker 出站 WSS 连中继实现内网穿透(公网远程驱动切号/列会话/导出, 天然无 shell), 网页多实例(一个浏览器多账号网页并行·per-tab 隔离·互不干扰)。无 IDE 依赖，Chrome / Kiwi(Android) / Edge 通用。道法自然·无为而无不为。",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "rt-flow 切号 + 内网穿透 + 多实例",
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "permissions": [
    "storage",
    "cookies",
    "scripting",
    "tabs",
    "alarms",
    "notifications",
    "declarativeNetRequestWithHostAccess"
  ],
  "host_permissions": [
    "https://app.devin.ai/*",
    "https://windsurf.com/*",
    "https://api.github.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://app.devin.ai/*"],
      "js": ["src/iso.js"],
      "run_at": "document_start",
      "all_frames": false,
      "world": "MAIN"
    },
    {
      "matches": ["https://app.devin.ai/*"],
      "js": ["src/content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ]
}
