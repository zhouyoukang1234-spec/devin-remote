{
  "name": "devin-git-auth",
  "displayName": "Devin Git Auth",
  "description": "Devin AI 多账号 GitHub 认证管理 · 账号列表/多选/批量连接断开 · 道法自然 · 无为而无不为",
  "version": "2.3.0",
  "publisher": "devaid",
  "license": "MIT",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["AI", "Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "devin-git-container",
          "title": "Git Auth",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "devin-git-container": [
        {
          "id": "devin-git.panel",
          "name": "GitHub Auth",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "devin-git.openPanel",
        "title": "Open Git Auth Panel",
        "category": "Devin Git"
      },
      {
        "command": "devin-git.refresh",
        "title": "刷新账号列表 (重载账号池)",
        "category": "Devin Git"
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/zhouyoukang/windsurf-assistant.git"
  }
}
