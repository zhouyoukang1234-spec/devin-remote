{
  "manifest_version": 3,
  "name": "dao · rt-flow 浏览器版 · 自动切换账号",
  "short_name": "rt-flow mobile",
  "version": "1.4.0",
  "description": "rt-flow 本体的浏览器/手机端移植：账号池 → email+password 换 auth1 → 注入 app.devin.ai 自动登录 → 额度耗尽自动切换。万法识别批量加号、对话实时追踪、账号本源概览、对话/知识库下载、水过无痕清理、Git 批量归一/连断(PAT)。无 IDE 依赖，Chrome / Kiwi(Android) / Edge 通用。道法自然·无为而无不为。",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "rt-flow 自动切换账号",
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "permissions": [
    "storage",
    "alarms",
    "cookies",
    "scripting",
    "notifications",
    "declarativeNetRequestWithHostAccess"
  ],
  "host_permissions": [
    "https://app.devin.ai/*",
    "https://windsurf.com/*",
    "https://api.github.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://app.devin.ai/*"],
      "js": ["src/content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ]
}
