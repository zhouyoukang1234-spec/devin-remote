{
  "name": "dao-vsix",
  "displayName": "Dao â€” Workspace as Server",
  "description": "Your IDE becomes a remote-control API server. Zero config. Auto token, auto port, auto tunnel.",
  "version": "1.4.3",
  "publisher": "dao",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "extensionKind": [
    "workspace"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dao-container",
          "title": "Dao â€” Workspace as Server",
          "icon": "media/icon.svg"
        },
        {
          "id": "devin-cloud-container",
          "title": "Devin Cloud",
          "icon": "media/devin-icon.svg"
        }
      ]
    },
    "views": {
      "dao-container": [],
      "devin-cloud-container": [
        {
          "id": "dao.cloudPanel",
          "name": "Devin Cloud",
          "type": "webview"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "dao.cloudPanel",
        "contents": "Devin Cloud Panel is starting..."
      }
    ],
    "configuration": {
      "title": "Dao",
      "properties": {
        "dao.port": {
          "type": "number",
          "default": 9920,
          "description": "Base port for HTTP server (auto-increment if occupied)"
        },
        "dao.token": {
          "type": "string",
          "default": "",
          "description": "Auth token (auto-generated if empty)"
        },
        "dao.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Auto-start server on activation"
        },
        "dao.githubPat": {
          "type": "string",
          "default": "",
          "description": "GitHub PAT for Gist auto-update (optional)"
        },
        "dao.gistId": {
          "type": "string",
          "default": "",
          "description": "Gist ID for connection info auto-update (optional)"
        },
        "dao.relayUrl": {
          "type": "string",
          "default": "",
          "description": "WebSocket relay URL(s), comma-separated"
        },
        "dao.autoBridge": {
          "type": "boolean",
          "default": false,
          "description": "Auto-connect WebSocket relay bridge (DEPRECATED — public tunneling moved to dao-bridge plugin)"
        },
        "dao.devinAutoSync": {
          "type": "boolean",
          "default": true,
          "description": "Auto-sync Windsurf credentials to Devin Cloud on startup"
        },
        "dao.accountSyncMode": {
          "type": "string",
          "enum": [
            "auto",
            "manual"
          ],
          "enumDescriptions": [
            "自动: 面板账号实时跟随 IDE(Windsurf) 当前登录账号",
            "手动: 不跟随 IDE, 由用户自行登录指定账号(账号对不上时用)"
          ],
          "default": "auto",
          "description": "账号同步模式 — 自动实时同源 IDE 账号 / 手动自控 (守柔, 保留操作空间)"
        },
        "dao.websiteLoginMode": {
          "type": "string",
          "enum": [
            "auto",
            "manual"
          ],
          "enumDescriptions": [
            "自动: 路由官网时深层注入 auth1 自动登录对应账号",
            "手动: 不注入, 打开官网后由用户自行登录"
          ],
          "default": "auto",
          "description": "路由官网登录模式 — 自动深层注入登录 / 手动登录 (守柔, 保留操作空间)"
        },
        "dao.injectAutoCleanup": {
          "type": "boolean",
          "default": true,
          "description": "自动注入自循环: 切换账号时, 默认自动清理旧账号 org 的旧注入 (关闭则保留)"
        }
      }
    },
    "commands": [
      {
        "command": "dao.startServer",
        "title": "Dao: Start Server"
      },
      {
        "command": "dao.stopServer",
        "title": "Dao: Stop Server"
      },
      {
        "command": "dao.showPort",
        "title": "Dao: Show Port & URL"
      },
      {
        "command": "dao.showInfo",
        "title": "Dao: Show Workspace Info"
      },
      {
        "command": "dao.copyConnection",
        "title": "Dao: Copy Connection Info"
      },
      {
        "command": "dao.regenerateToken",
        "title": "Dao: Regenerate Token"
      },
      {
        "command": "dao.devinLogin",
        "title": "Dao: Login Devin Cloud"
      },
      {
        "command": "dao.devinInject",
        "title": "Dao: Auto-Inject to Devin Cloud"
      },
      {
        "command": "dao.devinQuota",
        "title": "Dao: Refresh Devin Quota"
      },
      {
        "command": "dao.devinGitConnect",
        "title": "Dao: Connect GitHub PAT to Devin"
      },
      {
        "command": "dao.devinSessionCreate",
        "title": "Dao: Create Devin Session"
      },
      {
        "command": "dao.devinLogout",
        "title": "Dao: Logout Devin Cloud"
      },
      {
        "command": "dao.devinWindsurfAutoLogin",
        "title": "Dao: Windsurf Auto-Login to Devin Cloud"
      },
      {
        "command": "dao.devinCloudBrowser",
        "title": "Dao: Devin Cloud Browser"
      },
      {
        "command": "dao.devinCloudPanel",
        "title": "Dao: Devin Cloud Embedded Panel"
      },
      {
        "command": "dao.openDashboard",
        "title": "Dao: Open Dashboard"
      },
      {
        "command": "dao.openCloudPanel",
        "title": "Dao: Open Devin Cloud Panel"
      },
      {
        "command": "dao.toggleCloudPanel",
        "title": "Dao: Toggle Devin Cloud Panel"
      }
    ],
    "menus": {
      "editor/title/run": [
        {
          "command": "dao.openDashboard",
          "when": "true"
        },
        {
          "command": "dao.toggleCloudPanel",
          "when": "true"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "node ./build.js",
    "compile": "node ./build.js"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^3.9.2",
    "sucrase": "^3.35.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "ws": "^8.16.0"
  }
}